{
  "name": "@venegrad/vue3-autocomplete",
  "version": "1.0.8",
  "description": "Simple autocomplete field for vue3 and nuxt3. Tags, async loading list, dynamic, async, dropdown list.",
  "author": "venegrad <venegrad@gmail.com> (https://venegrad.com/)",
  "license": "MIT",
  "homepage": "https://github.com/Venegrad/vue3-autocomplete#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Venegrad/vue3-autocomplete.git"
  },
  "bugs": {
    "url": "https://github.com/Venegrad/vue3-autocomplete/issues",
    "email": "venegrad@gmail.com"
  },
  "keywords": [
    "autocomplete",
    "autosuggest",
    "vue-tags",
    "vue3-tags",
    "tags",
    "vue-tags",
    "select",
    "search",
    "searchbox",
    "enhanced input",
    "component",
    "vue-component",
    "vue-autocomplete",
    "v-autocomplete",
    "vue",
    "vue3",
    "vue3js",
    "vuejs3",
    "nuxt3",
    "nuxtjs3"
  ],
  "main": "dist/venAutocomplete.ssr.js",
  "browser": "dist/venAutocomplete.esm.js",
  "module": "dist/venAutocomplete.esm.js",
  "unpkg": "dist/venAutocomplete.min.js",
  "style": "dist/venAutocomplete.css",
  "files": [
    "dist/*",
    "src/**/*.vue",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "preview": "vite preview",
    "prebuild": "rimraf ./dist",
    "build": "cross-env NODE_ENV=production rollup --config build/rollup.config.mjs",
    "build:ssr": "cross-env NODE_ENV=production rollup --config build/rollup.config.mjs --format cjs",
    "build:es": "cross-env NODE_ENV=production rollup --config build/rollup.config.mjs --format es",
    "build:unpkg": "cross-env NODE_ENV=production rollup --config build/rollup.config.mjs --format iife",
    "build:all": "yarn build && yarn build:ssr && yarn build:es && yarn build:unpkg"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/compiler-sfc": "^3.5.32",
    "cross-env": "^10.1.0",
    "minimist": "^1.2.8",
    "postcss": "^8.5.9",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-vue": "^6.0.0",
    "vite": "^8.0.8",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
